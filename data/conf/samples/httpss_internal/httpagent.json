{


"httpAgent": [
	{
		"id": "httpss",
		"url": "/httpss",
		"conns": {
			"*sessions": [{"connIDs": ["*localhost"]}]
		},
		"requestPayload":	"*url",
		"replyPayload":	"*text",
		"requestProcessors": [
			{
				"id": "Authorization",
				"filters": ["*string:~*req.requestType:Authorization"],
				"tenant": "cgrates.org",
				"flags": ["*event"],
				"requestFields":[
					{"tag": "OptAuth", "path": "*opts.*authorize", "type": "*constant",
						"value": "true"},
					{"tag": "OptAccounts", "path": "*opts.*accounts", "type": "*constant",
						"value": "true"},
					{"tag": "OptUsage", "path": "*opts.*usage", "type": "*constant",
						"value": "1000000"}, // auth 1GB
					{"tag": "OriginID", "path": "*opts.*originID", "type": "*variable",
						"value": "~*req.sessionID", "mandatory": true},
					{"tag": "Account", "path": "*cgreq.IMSI", "type": "*variable",
						"value": "~*req.imsi", "mandatory": true},
					{"tag": "SetupTime", "path": "*cgreq.SetupTime", "type": "*constant",
						"value": "*now"}
				],
				"replyFields":[
					{"tag": "Error", "filters": ["*notempty:~*cgrep.Error:"], "path": "*rep.Error",
					"type": "*variable", "value": "~*cgrep.Error", "blocker": true},
					{"tag": "MaxUsage", "path": "*rep.MaxUsage", "type": "*variable",
						"value": "~*cgrep.MaxUsage.*primary{*units}", "mandatory": true}
				]
			},
			{
				"id": "SessionStart",
				"filters": ["*string:~*req.requestType:SessionStart"],
				"tenant": "cgrates.org",
				"flags": ["*event"],
				"requestFields":[
					{"tag": "OptSession", "path": "*opts.*session", "type": "*constant",
						"value": "true"},
					{"tag": "OptAccounts", "path": "*opts.*accounts", "type": "*constant",
						"value": "true"},
					{"tag": "OptInterimUsage", "path": "*opts.*interimUsage", "type": "*constant",
						"value": "50000"}, // auth 50MB
					{"tag": "OriginID", "path": "*opts.*originID", "type": "*variable",
						"value": "~*req.sessionID", "mandatory": true},
					{"tag": "Account", "path": "*cgreq.IMSI", "type": "*variable",
						"value": "~*req.imsi", "mandatory": true},
					{"tag": "SetupTime", "path": "*cgreq.SetupTime", "type": "*constant",
						"value": "*now"}
				],
				"replyFields":[
					{"tag": "Error", "filters": ["*notempty:~*cgrep.Error:"], "path": "*rep.Error",
					"type": "*variable", "value": "~*cgrep.Error", "blocker": true},
					{"tag": "MaxUsage", "path": "*rep.MaxUsage", "type": "*variable",
						"value": "~*cgrep.MaxUsage.*primary{*units}", "mandatory": true}
				]
			},
			{
				"id": "SessionUpdate",
				"filters": ["*string:~*req.requestType:SessionUpdate"],
				"tenant": "cgrates.org",
				"flags": ["*event"],
				"requestFields":[
					{"tag": "OptSession", "path": "*opts.*session", "type": "*constant",
						"value": "true"},
					{"tag": "OptAccounts", "path": "*opts.*accounts", "type": "*constant",
						"value": "true"},
					{"tag": "OptInterimUsage", "path": "*opts.*interimUsage", "type": "*constant",
						"value": "50000"}, // auth 50MB
					{"tag": "OptPreviousUsage", "filters": ["*notempty:~*req.usedUnits:"],
					    "path": "*opts.*interimConsumed", "type": "*variable",
						"value": "~*req.usedUnits"}, // confirmedConsumed
					{"tag": "OptTotalUsage", "filters": ["*notempty:~*req.totalUnits:"],
					    "path": "*opts.*totalUsage", "type": "*variable",
						"value": "~*req.totalUnits"},
					{"tag": "OriginID", "path": "*opts.*originID", "type": "*variable",
						"value": "~*req.sessionID", "mandatory": true},
					{"tag": "Account", "path": "*cgreq.IMSI", "type": "*variable",
						"value": "~*req.imsi", "mandatory": true},
					{"tag": "SetupTime", "path": "*cgreq.SetupTime", "type": "*constant",
						"value": "*now"}
				],
				"replyFields":[
					{"tag": "Error", "filters": ["*notempty:~*cgrep.Error:"], "path": "*rep.Error",
					"type": "*variable", "value": "~*cgrep.Error", "blocker": true},
					{"tag": "MaxUsage", "path": "*rep.MaxUsage", "type": "*variable",
						"value": "~*cgrep.MaxUsage.*primary{*units}", "mandatory": true}
				]
			},
			{
				"id": "SessionTerminate",
				"filters": ["*string:~*req.requestType:Terminate"],
				"tenant": "cgrates.org",
				"flags": ["*event"],
				"requestFields":[
					{"tag": "OptSession", "path": "*opts.*session", "type": "*constant",
						"value": "true"},
					{"tag": "OptAccounts", "path": "*opts.*accounts", "type": "*constant",
						"value": "true"},
					{"tag": "OptTerminate", "path": "*opts.*terminate", "type": "*constant",
						"value": "true"},
					{"tag": "OptUsageRecord", "path": "*opts.*ur", "type": "*constant",
						"value": "true"},
					{"tag": "OptTotalUsage", "path": "*opts.*totalUsage", "type": "*variable",
						"value": "~*req.totalUnits"}, // auth 50MB
					{"tag": "OptPreviousUsage", "path": "*opts.*interimConsumed", "type": "*variable",
						"value": "~*req.usedUnits"}, // confirmedConsumed
					{"tag": "OriginID", "path": "*opts.*originID", "type": "*variable",
						"value": "~*req.sessionID", "mandatory": true},
					{"tag": "Account", "path": "*cgreq.IMSI", "type": "*variable",
						"value": "~*req.imsi", "mandatory": true},
					{"tag": "SetupTime", "path": "*cgreq.SetupTime", "type": "*constant",
						"value": "*now"}
				],
				"replyFields":[
					{"tag": "Error", "filters": ["*notempty:~*cgrep.Error:"], "path": "*rep.Error",
					"type": "*variable", "value": "~*cgrep.Error", "blocker": true},
					{"tag": "MaxUsage", "path": "*rep.MaxUsage", "type": "*variable",
						"value": "~*cgrep.MaxUsage.*primary{*units}", "mandatory": true}
				]
			},
		]
	}
]


}